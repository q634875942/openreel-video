# PostHog Analytics (optional)
# Get your keys at https://posthog.com
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

# ----------------------------------------------------------------------
# AI providers (feat-005). Copy this file to .env.local (gitignored) and
# fill in whichever provider keys you have. In production, end users
# supply keys through the settings UI (feat-006); these dev-only vars
# exist so feat-005 can be tested end-to-end before the UI is built.
# ----------------------------------------------------------------------

# Anthropic Claude — https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# OpenAI (ChatGPT) — https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# DeepSeek — https://platform.deepseek.com/api_keys
VITE_DEEPSEEK_API_KEY=

# OpenAI-compatible (Kimi / GLM / Ollama / vLLM / self-hosted).
# Provide baseURL and model too — the Compatible provider needs all three.
VITE_COMPATIBLE_API_KEY=
VITE_COMPATIBLE_BASE_URL=
VITE_COMPATIBLE_MODEL=
